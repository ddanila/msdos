BACKUP_OUT   := $(BACKUP_DIR)/BACKUP.COM

RESTORE_DIR  := $(CMD_DIR)/RESTORE
RESTORE_OUT  := $(RESTORE_DIR)/RESTORE.COM

GRAFTABL_DIR := $(CMD_DIR)/GRAFTABL
GRAFTABL_OUT := $(GRAFTABL_DIR)/GRAFTABL.COM

KEYB_DIR     := $(CMD_DIR)/KEYB
KEYB_OUT     := $(KEYB_DIR)/KEYB.COM

SHARE_DIR    := $(CMD_DIR)/SHARE
