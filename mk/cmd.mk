# ---------------------------------------------------------------------------
# CMD (command.com + utilities)
# ---------------------------------------------------------------------------
CMD_DIR  := $(SRC)/CMD
COMMAND_DIR := $(CMD_DIR)/COMMAND
COMMAND_OUT := $(COMMAND_DIR)/COMMAND.COM

SYS_DIR    := $(CMD_DIR)/SYS
SYS_OUT    := $(SYS_DIR)/SYS.COM

FORMAT_DIR := $(CMD_DIR)/FORMAT
FORMAT_OUT := $(FORMAT_DIR)/FORMAT.COM

CHKDSK_DIR := $(CMD_DIR)/CHKDSK
CHKDSK_OUT := $(CHKDSK_DIR)/CHKDSK.COM

cmd: $(COMMAND_OUT) $(SYS_OUT) $(FORMAT_OUT) $(CHKDSK_OUT)

# COMMAND include paths (two levels up from CMD/COMMAND/)
COMMAND_AINC := -I. -ID:\\TOOLS\\INC -I..\\..\\INC -I..\\..\\DOS

# ---------------------------------------------------------------------------
# Step 1: BUILDMSG generates COMMAND.CTL + COMMAND.CL[1-4,A-F]
# ---------------------------------------------------------------------------
$(COMMAND_DIR)/COMMAND.CTL: $(COMMAND_DIR)/COMMAND.SKL $(MESSAGES_OUT)
	cd $(COMMAND_DIR) && $(BUILDMSG) "..\\..\\MESSAGES\\USA-MS" COMMAND.SKL

# All CL files are side-effects of the same BUILDMSG run
$(COMMAND_DIR)/COMMAND.CL1 $(COMMAND_DIR)/COMMAND.CL2 \
$(COMMAND_DIR)/COMMAND.CL3 $(COMMAND_DIR)/COMMAND.CL4 \
$(COMMAND_DIR)/COMMAND.CLA $(COMMAND_DIR)/COMMAND.CLB \
$(COMMAND_DIR)/COMMAND.CLC $(COMMAND_DIR)/COMMAND.CLD \
$(COMMAND_DIR)/COMMAND.CLE $(COMMAND_DIR)/COMMAND.CLF: \
    $(COMMAND_DIR)/COMMAND.CTL

# ---------------------------------------------------------------------------
# Step 2: Assemble COMMAND objects
# ---------------------------------------------------------------------------
$(COMMAND_DIR)/COMMAND1.OBJ: $(COMMAND_DIR)/COMMAND1.ASM \
    $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "COMMAND1.ASM,COMMAND1.OBJ;"

$(COMMAND_DIR)/COMMAND2.OBJ: $(COMMAND_DIR)/COMMAND2.ASM \
    $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "COMMAND2.ASM,COMMAND2.OBJ;"

$(COMMAND_DIR)/RUCODE.OBJ: $(COMMAND_DIR)/RUCODE.ASM \
    $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "RUCODE.ASM,RUCODE.OBJ;"

$(COMMAND_DIR)/RDATA.OBJ: $(COMMAND_DIR)/RDATA.ASM \
    $(COMMAND_DIR)/COMMAND.CLA $(COMMAND_DIR)/COMMAND.CL3 \
    $(COMMAND_DIR)/COMMAND.CL4 $(COMMAND_DIR)/COMMAND.CLD \
    $(COMMAND_DIR)/COMMAND.CLC $(COMMAND_DIR)/COMMAND.CLE \
    $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "RDATA.ASM,RDATA.OBJ;"

$(COMMAND_DIR)/INIT.OBJ: $(COMMAND_DIR)/INIT.ASM \
    $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "INIT.ASM,INIT.OBJ;"

$(COMMAND_DIR)/IPARSE.OBJ: $(COMMAND_DIR)/IPARSE.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "IPARSE.ASM,IPARSE.OBJ;"

$(COMMAND_DIR)/UINIT.OBJ: $(COMMAND_DIR)/UINIT.ASM \
    $(COMMAND_DIR)/COMMAND.CLB $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "UINIT.ASM,UINIT.OBJ;"

$(COMMAND_DIR)/TCODE.OBJ: $(COMMAND_DIR)/TCODE.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TCODE.ASM,TCODE.OBJ;"

$(COMMAND_DIR)/TBATCH.OBJ: $(COMMAND_DIR)/TBATCH.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TBATCH.ASM,TBATCH.OBJ;"

$(COMMAND_DIR)/TBATCH2.OBJ: $(COMMAND_DIR)/TBATCH2.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TBATCH2.ASM,TBATCH2.OBJ;"

$(COMMAND_DIR)/TFOR.OBJ: $(COMMAND_DIR)/TFOR.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TFOR.ASM,TFOR.OBJ;"

$(COMMAND_DIR)/TCMD1A.OBJ: $(COMMAND_DIR)/TCMD1A.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TCMD1A.ASM,TCMD1A.OBJ;"

$(COMMAND_DIR)/TCMD1B.OBJ: $(COMMAND_DIR)/TCMD1B.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TCMD1B.ASM,TCMD1B.OBJ;"

$(COMMAND_DIR)/TCMD2A.OBJ: $(COMMAND_DIR)/TCMD2A.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TCMD2A.ASM,TCMD2A.OBJ;"

$(COMMAND_DIR)/TCMD2B.OBJ: $(COMMAND_DIR)/TCMD2B.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TCMD2B.ASM,TCMD2B.OBJ;"

$(COMMAND_DIR)/TENV.OBJ: $(COMMAND_DIR)/TENV.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TENV.ASM,TENV.OBJ;"

$(COMMAND_DIR)/TENV2.OBJ: $(COMMAND_DIR)/TENV2.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TENV2.ASM,TENV2.OBJ;"

$(COMMAND_DIR)/TMISC1.OBJ: $(COMMAND_DIR)/TMISC1.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TMISC1.ASM,TMISC1.OBJ;"

$(COMMAND_DIR)/TMISC2.OBJ: $(COMMAND_DIR)/TMISC2.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TMISC2.ASM,TMISC2.OBJ;"

$(COMMAND_DIR)/TPIPE.OBJ: $(COMMAND_DIR)/TPIPE.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TPIPE.ASM,TPIPE.OBJ;"

$(COMMAND_DIR)/PARSE2.OBJ: $(COMMAND_DIR)/PARSE2.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "PARSE2.ASM,PARSE2.OBJ;"

$(COMMAND_DIR)/PATH1.OBJ: $(COMMAND_DIR)/PATH1.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "PATH1.ASM,PATH1.OBJ;"

$(COMMAND_DIR)/PATH2.OBJ: $(COMMAND_DIR)/PATH2.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "PATH2.ASM,PATH2.OBJ;"

$(COMMAND_DIR)/TUCODE.OBJ: $(COMMAND_DIR)/TUCODE.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TUCODE.ASM,TUCODE.OBJ;"

$(COMMAND_DIR)/COPY.OBJ: $(COMMAND_DIR)/COPY.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "COPY.ASM,COPY.OBJ;"

$(COMMAND_DIR)/COPYPR1.OBJ: $(COMMAND_DIR)/COPYPR1.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "COPYPR1.ASM,COPYPR1.OBJ;"

$(COMMAND_DIR)/COPYPR2.OBJ: $(COMMAND_DIR)/COPYPR2.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "COPYPR2.ASM,COPYPR2.OBJ;"

$(COMMAND_DIR)/CPARSE.OBJ: $(COMMAND_DIR)/CPARSE.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "CPARSE.ASM,CPARSE.OBJ;"

$(COMMAND_DIR)/TPARSE.OBJ: $(COMMAND_DIR)/TPARSE.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TPARSE.ASM,TPARSE.OBJ;"

$(COMMAND_DIR)/TPRINTF.OBJ: $(COMMAND_DIR)/TPRINTF.ASM \
    $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TPRINTF.ASM,TPRINTF.OBJ;"

$(COMMAND_DIR)/TDATA.OBJ: $(COMMAND_DIR)/TDATA.ASM \
    $(COMMAND_DIR)/COMMAND.CLF $(COMMAND_DIR)/COMMAND.CL1 \
    $(COMMAND_DIR)/COMMAND.CL2 $(COMMAND_DIR)/COMMAND.CTL
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TDATA.ASM,TDATA.OBJ;"

$(COMMAND_DIR)/TSPC.OBJ: $(COMMAND_DIR)/TSPC.ASM
	cd $(COMMAND_DIR) && $(MASM) "$(AFLAGS) $(COMMAND_AINC)" "TSPC.ASM,TSPC.OBJ;"

# ---------------------------------------------------------------------------
# Step 3: Link -> COMMAND.EXE -> EXE2BIN -> COMMAND.COM
# ---------------------------------------------------------------------------
COMMAND_OBJS := COMMAND1.OBJ COMMAND2.OBJ RUCODE.OBJ RDATA.OBJ INIT.OBJ \
    IPARSE.OBJ UINIT.OBJ TCODE.OBJ TBATCH.OBJ TBATCH2.OBJ TFOR.OBJ \
    TCMD1A.OBJ TCMD1B.OBJ TCMD2A.OBJ TCMD2B.OBJ TENV.OBJ TENV2.OBJ \
    TMISC1.OBJ TMISC2.OBJ TPIPE.OBJ PARSE2.OBJ PATH1.OBJ PATH2.OBJ \
    TUCODE.OBJ COPY.OBJ COPYPR1.OBJ COPYPR2.OBJ CPARSE.OBJ \
    TPARSE.OBJ TPRINTF.OBJ TDATA.OBJ TSPC.OBJ

COMMAND_OBJ_PATHS := $(addprefix $(COMMAND_DIR)/,$(COMMAND_OBJS))

$(COMMAND_DIR)/COMMAND.EXE: $(COMMAND_OBJ_PATHS)
	cd $(COMMAND_DIR) && $(LINK) "@COMMAND.LNK"

$(COMMAND_OUT): $(COMMAND_DIR)/COMMAND.EXE
	cd $(COMMAND_DIR) && $(EXE2BIN) "COMMAND.EXE COMMAND.COM"

# ---------------------------------------------------------------------------
# SYS (sys.com)
# ---------------------------------------------------------------------------
# Include paths: current dir (for SYSHDR.INC, generated SYSMSG.INC/CL*) + INC/
SYS_AINC := -I. -ID:\\TOOLS\\INC -I..\\..\\INC

# Step 1: BUILDMSG generates SYS.CTL + SYS.CL[1,2,A-D]
$(SYS_DIR)/SYS.CTL: $(SYS_DIR)/SYS.SKL $(MESSAGES_OUT)
	cd $(SYS_DIR) && $(BUILDMSG) "..\\..\\MESSAGES\\USA-MS" SYS.SKL

$(SYS_DIR)/SYS.CL1 $(SYS_DIR)/SYS.CL2 \
$(SYS_DIR)/SYS.CLA $(SYS_DIR)/SYS.CLB \
$(SYS_DIR)/SYS.CLC $(SYS_DIR)/SYS.CLD: \
    $(SYS_DIR)/SYS.CTL

# Step 2: Assemble objects
$(SYS_DIR)/SYS1.OBJ: $(SYS_DIR)/SYS1.ASM $(SYS_DIR)/SYS.CTL
	cd $(SYS_DIR) && $(MASM) "$(AFLAGS) $(SYS_AINC)" "SYS1.ASM,SYS1.OBJ;"

$(SYS_DIR)/SYS2.OBJ: $(SYS_DIR)/SYS2.ASM $(SYS_DIR)/SYS.CTL
	cd $(SYS_DIR) && $(MASM) "$(AFLAGS) $(SYS_AINC)" "SYS2.ASM,SYS2.OBJ;"

$(SYS_DIR)/SYSSR.OBJ: $(SYS_DIR)/SYSSR.ASM \
    $(SYS_DIR)/SYS.CTL $(SYS_DIR)/SYS.CL1 $(SYS_DIR)/SYS.CL2 \
    $(SYS_DIR)/SYS.CLA $(SYS_DIR)/SYS.CLB \
    $(SYS_DIR)/SYS.CLC $(SYS_DIR)/SYS.CLD
	cd $(SYS_DIR) && $(MASM) "$(AFLAGS) $(SYS_AINC)" "SYSSR.ASM,SYSSR.OBJ;"

# Step 3: Link -> SYS.EXE -> EXE2BIN -> SYS.COM
$(SYS_DIR)/SYS.EXE: $(SYS_DIR)/SYS1.OBJ $(SYS_DIR)/SYS2.OBJ $(SYS_DIR)/SYSSR.OBJ
	cd $(SYS_DIR) && $(LINK) "@SYS.LNK"

$(SYS_OUT): $(SYS_DIR)/SYS.EXE
	cd $(SYS_DIR) && $(EXE2BIN) "SYS.EXE SYS.COM"

# ---------------------------------------------------------------------------
# FORMAT (format.com)
# ---------------------------------------------------------------------------
# Uses CONVERT.EXE (not EXE2BIN) to produce COM from EXE.
# MSFOR.ASM includes BOOT.CL1 (from BOOT/) and BOOT11.INC (from INC/).
FORMAT_AINC := -I. -ID:\\TOOLS\\INC -I..\\..\\INC

# Step 1: BUILDMSG generates FORMAT.CTL + FORMAT.CL[1,A,B,C]
$(FORMAT_DIR)/FORMAT.CTL: $(FORMAT_DIR)/FORMAT.SKL $(MESSAGES_OUT)
	cd $(FORMAT_DIR) && $(BUILDMSG) "..\\..\\MESSAGES\\USA-MS" FORMAT.SKL

$(FORMAT_DIR)/FORMAT.CL1 $(FORMAT_DIR)/FORMAT.CLA \
$(FORMAT_DIR)/FORMAT.CLB $(FORMAT_DIR)/FORMAT.CLC: \
    $(FORMAT_DIR)/FORMAT.CTL

# Step 2: copy BOOT.CL1 to FORMAT dir (MSFOR.ASM: include BOOT.CL1)
$(FORMAT_DIR)/BOOT.CL1: $(SRC)/BOOT/BOOT.CL1
	cp $< $@

# Step 3: Assemble objects
$(FORMAT_DIR)/DISPLAY.OBJ: $(FORMAT_DIR)/DISPLAY.ASM $(FORMAT_DIR)/FORMAT.CTL
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "DISPLAY.ASM,DISPLAY.OBJ;"

$(FORMAT_DIR)/FORINIT.OBJ: $(FORMAT_DIR)/FORINIT.ASM $(FORMAT_DIR)/FORMAT.CTL
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "FORINIT.ASM,FORINIT.OBJ;"

$(FORMAT_DIR)/FORLABEL.OBJ: $(FORMAT_DIR)/FORLABEL.ASM $(FORMAT_DIR)/FORMAT.CTL
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "FORLABEL.ASM,FORLABEL.OBJ;"

$(FORMAT_DIR)/FORMAT.OBJ: $(FORMAT_DIR)/FORMAT.ASM $(FORMAT_DIR)/FORMAT.CTL
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "FORMAT.ASM,FORMAT.OBJ;"

$(FORMAT_DIR)/FORPROC.OBJ: $(FORMAT_DIR)/FORPROC.ASM $(FORMAT_DIR)/FORMAT.CTL
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "FORPROC.ASM,FORPROC.OBJ;"

$(FORMAT_DIR)/MSFOR.OBJ: $(FORMAT_DIR)/MSFOR.ASM $(FORMAT_DIR)/FORMAT.CTL \
    $(FORMAT_DIR)/BOOT.CL1
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "MSFOR.ASM,MSFOR.OBJ;"

$(FORMAT_DIR)/FOREXEC.OBJ: $(FORMAT_DIR)/FOREXEC.ASM
	cd $(FORMAT_DIR) && $(MASM) "$(AFLAGS) $(FORMAT_AINC)" "FOREXEC.ASM,FOREXEC.OBJ;"

# Step 4: Link → FORMAT.EXE; Step 5: CONVERT → FORMAT.COM
FORMAT_OBJS := $(addprefix $(FORMAT_DIR)/,\
    DISPLAY.OBJ FORINIT.OBJ FORLABEL.OBJ FORMAT.OBJ \
    FORPROC.OBJ MSFOR.OBJ FOREXEC.OBJ)

$(FORMAT_DIR)/FORMAT.EXE: $(FORMAT_OBJS)
	cd $(FORMAT_DIR) && $(LINK) "@FORMAT.LNK"

$(FORMAT_OUT): $(FORMAT_DIR)/FORMAT.EXE
	cd $(FORMAT_DIR) && $(CONVERT) "FORMAT.EXE"

# ---------------------------------------------------------------------------
# CHKDSK (chkdsk.com)
# ---------------------------------------------------------------------------
# SKL defines classes A,B,C,D only; CHKDISP.ASM's Msg_Services macro also
# INCLUDEs CL1 and CL2, so we touch empty stubs for those after BUILDMSG.
CHKDSK_AINC := -I. -ID:\\TOOLS\\INC -I..\\..\\INC

# Step 1: BUILDMSG generates CHKDSK.CTL + CHKDSK.CL[A,B,C,D]
# Also touch empty CL1/CL2 stubs (Msg_Services INCLUDEs them but SKL has no class 1/2)
$(CHKDSK_DIR)/CHKDSK.CTL: $(CHKDSK_DIR)/CHKDSK.SKL $(MESSAGES_OUT)
	cd $(CHKDSK_DIR) && $(BUILDMSG) "..\\..\\MESSAGES\\USA-MS" CHKDSK.SKL
	touch $(CHKDSK_DIR)/CHKDSK.CL1 $(CHKDSK_DIR)/CHKDSK.CL2

$(CHKDSK_DIR)/CHKDSK.CLA $(CHKDSK_DIR)/CHKDSK.CLB \
$(CHKDSK_DIR)/CHKDSK.CLC $(CHKDSK_DIR)/CHKDSK.CLD \
$(CHKDSK_DIR)/CHKDSK.CL1 $(CHKDSK_DIR)/CHKDSK.CL2: \
    $(CHKDSK_DIR)/CHKDSK.CTL

# Step 2: Assemble objects
# Most objects don't include CTL/CL files directly; only CHKDISP does (via Msg_Services).
$(CHKDSK_DIR)/CHKDISK.OBJ: $(CHKDSK_DIR)/CHKDISK.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKDISK.ASM,CHKDISK.OBJ;"

$(CHKDSK_DIR)/CHKDISP.OBJ: $(CHKDSK_DIR)/CHKDISP.ASM \
    $(CHKDSK_DIR)/CHKDSK.CTL \
    $(CHKDSK_DIR)/CHKDSK.CLA $(CHKDSK_DIR)/CHKDSK.CLB \
    $(CHKDSK_DIR)/CHKDSK.CLC $(CHKDSK_DIR)/CHKDSK.CLD \
    $(CHKDSK_DIR)/CHKDSK.CL1 $(CHKDSK_DIR)/CHKDSK.CL2
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKDISP.ASM,CHKDISP.OBJ;"

$(CHKDSK_DIR)/CHKDSK1.OBJ: $(CHKDSK_DIR)/CHKDSK1.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKDSK1.ASM,CHKDSK1.OBJ;"

$(CHKDSK_DIR)/CHKDSK2.OBJ: $(CHKDSK_DIR)/CHKDSK2.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKDSK2.ASM,CHKDSK2.OBJ;"

$(CHKDSK_DIR)/CHKFAT.OBJ: $(CHKDSK_DIR)/CHKFAT.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKFAT.ASM,CHKFAT.OBJ;"

$(CHKDSK_DIR)/CHKINIT.OBJ: $(CHKDSK_DIR)/CHKINIT.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKINIT.ASM,CHKINIT.OBJ;"

$(CHKDSK_DIR)/CHKPRMT.OBJ: $(CHKDSK_DIR)/CHKPRMT.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKPRMT.ASM,CHKPRMT.OBJ;"

$(CHKDSK_DIR)/CHKPROC2.OBJ: $(CHKDSK_DIR)/CHKPROC2.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKPROC2.ASM,CHKPROC2.OBJ;"

$(CHKDSK_DIR)/CHKPROC.OBJ: $(CHKDSK_DIR)/CHKPROC.ASM
	cd $(CHKDSK_DIR) && $(MASM) "$(AFLAGS) $(CHKDSK_AINC)" "CHKPROC.ASM,CHKPROC.OBJ;"

# Step 3: Link → CHKDSK.EXE; Step 4: CONVERT → CHKDSK.COM
CHKDSK_OBJS := $(addprefix $(CHKDSK_DIR)/,\
    CHKDISK.OBJ CHKDISP.OBJ CHKDSK1.OBJ CHKDSK2.OBJ \
    CHKFAT.OBJ CHKINIT.OBJ CHKPRMT.OBJ CHKPROC2.OBJ CHKPROC.OBJ)

$(CHKDSK_DIR)/CHKDSK.EXE: $(CHKDSK_OBJS)
	cd $(CHKDSK_DIR) && $(LINK) "@CHKDSK.LNK"

$(CHKDSK_OUT): $(CHKDSK_DIR)/CHKDSK.EXE
	cd $(CHKDSK_DIR) && $(CONVERT) "CHKDSK.EXE"
