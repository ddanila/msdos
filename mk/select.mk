# ---------------------------------------------------------------------------
# SELECT (select.exe, select.dat, select.com, select.hlp)
# SELECT is 1 level deep (SRC/SELECT/), so .. paths work directly.
# ---------------------------------------------------------------------------
SELECT_DIR  := $(SRC)/SELECT
FDISK_DIR   := $(SRC)/CMD/FDISK
TOOLS_DIR   := $(SRC)/TOOLS

# Include paths: local dir + SRC/INC (one level up)
SELECT_AINC := -I. -I..\\INC

select: \
    $(SELECT_DIR)/SELECT.COM \
    $(SELECT_DIR)/SELECT.HLP \
    $(SELECT_DIR)/SELECT.EXE \
    $(SELECT_DIR)/SELECT.DAT

# ---------------------------------------------------------------------------
# SELECT.CTL + CL files (BUILDMSG — SELECT.SKL has :util header)
# ---------------------------------------------------------------------------
$(SELECT_DIR)/SELECT.CTL: $(SELECT_DIR)/SELECT.SKL $(MESSAGES_OUT)
	cd $(SELECT_DIR) && $(BUILDMSG) "..\\MESSAGES\\USA-MS" SELECT.SKL

# CL side-effects of the same BUILDMSG run
$(SELECT_DIR)/SELECT.CLA: $(SELECT_DIR)/SELECT.CTL

# ---------------------------------------------------------------------------
# SELECT.COM  (simplest output: sstub.asm → link → exe2bin)
# ---------------------------------------------------------------------------
$(SELECT_DIR)/SSTUB.OBJ: $(SELECT_DIR)/SSTUB.ASM $(SELECT_DIR)/SELECT.CTL
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "SSTUB.ASM,SSTUB.OBJ;"

$(SELECT_DIR)/SSTUB.EXE: $(SELECT_DIR)/SSTUB.OBJ
	cd $(SELECT_DIR) && $(LINK) "SSTUB;"

$(SELECT_DIR)/SELECT.COM: $(SELECT_DIR)/SSTUB.EXE
	cd $(SELECT_DIR) && $(EXE2BIN) "SSTUB.EXE SELECT.COM"

# ---------------------------------------------------------------------------
# SELECT.HLP  (ASC2HLP.EXE is a pre-built tool in TOOLS/)
# ---------------------------------------------------------------------------
$(SELECT_DIR)/SELECT.HLP: $(SELECT_DIR)/USA.TXT
	cd $(SELECT_DIR) && $(BIN)/dos-run $(TOOLS_DIR)/ASC2HLP.EXE USA.TXT SELECT.HLP

# ---------------------------------------------------------------------------
# FDBOOT.INC dependency chain (needed for BOOTREC.OBJ → SELECT.EXE)
# ---------------------------------------------------------------------------

# Step 1: FDISK5.CL1 (class 1 SKL → NOSRVBLD)
$(FDISK_DIR)/FDISK5.CL1: $(FDISK_DIR)/FDISK5.SKL $(MESSAGES_OUT)
	cd $(FDISK_DIR) && $(NOSRVBLD) FDISK5.SKL "..\\..\\MESSAGES\\USA-MS.MSG"

# Step 2: FDBOOT.OBJ
$(FDISK_DIR)/FDBOOT.OBJ: $(FDISK_DIR)/FDBOOT.ASM $(FDISK_DIR)/FDISK5.CL1
	cd $(FDISK_DIR) && $(MASM) "$(AFLAGS) -I." "FDBOOT.ASM,FDBOOT.OBJ;"

# Step 3: FDBOOT.EXE
$(FDISK_DIR)/FDBOOT.EXE: $(FDISK_DIR)/FDBOOT.OBJ
	cd $(FDISK_DIR) && $(LINK) "FDBOOT;"

# Step 4: FDBOOT.BIN
$(FDISK_DIR)/FDBOOT.BIN: $(FDISK_DIR)/FDBOOT.EXE
	cd $(FDISK_DIR) && $(EXE2BIN) "FDBOOT.EXE FDBOOT.BIN"

# Step 5: FDBOOT.INC via DBOF
$(FDISK_DIR)/FDBOOT.INC: $(FDISK_DIR)/FDBOOT.BIN
	cd $(FDISK_DIR) && $(DBOF) "FDBOOT.BIN FDBOOT.INC 600 200"

# Step 6: BOOTREC.OBJ (assembled in FDISK dir where FDBOOT.INC lives)
$(FDISK_DIR)/BOOTREC.OBJ: $(FDISK_DIR)/BOOTREC.ASM $(FDISK_DIR)/FDBOOT.INC
	cd $(FDISK_DIR) && $(MASM) "$(AFLAGS) -I." "BOOTREC.ASM,BOOTREC.OBJ;"

# Step 7: Copy BOOTREC.OBJ to SELECT dir (SELECT.LNK expects it locally)
$(SELECT_DIR)/BOOTREC.OBJ: $(FDISK_DIR)/BOOTREC.OBJ
	cp $(FDISK_DIR)/BOOTREC.OBJ $(SELECT_DIR)/BOOTREC.OBJ

# ---------------------------------------------------------------------------
# SERVICES.LIB objects
# ---------------------------------------------------------------------------
$(SELECT_DIR)/SELQUIT.OBJ: $(SELECT_DIR)/SELQUIT.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "SELQUIT.ASM,SELQUIT.OBJ;"

$(SELECT_DIR)/SELCHILD.OBJ: $(SELECT_DIR)/SELCHILD.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "SELCHILD.ASM,SELCHILD.OBJ;"

$(SELECT_DIR)/SERVICES.OBJ: $(SELECT_DIR)/SERVICES.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "SERVICES.ASM,SERVICES.OBJ;"

$(SELECT_DIR)/GET_HELP.OBJ: $(SELECT_DIR)/GET_HELP.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "GET_HELP.ASM,GET_HELP.OBJ;"

$(SELECT_DIR)/SELSERV.OBJ: $(SELECT_DIR)/SELSERV.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "SELSERV.ASM,SELSERV.OBJ;"

$(SELECT_DIR)/SERVICES.LIB: \
    $(SELECT_DIR)/SELQUIT.OBJ $(SELECT_DIR)/SELCHILD.OBJ \
    $(SELECT_DIR)/SERVICES.OBJ $(SELECT_DIR)/GET_HELP.OBJ \
    $(SELECT_DIR)/SELSERV.OBJ
	rm -f $(SELECT_DIR)/SERVICES.LIB
	cd $(SELECT_DIR) && $(LIB) "SERVICES.LIB -+ SELQUIT;"
	cd $(SELECT_DIR) && $(LIB) "SERVICES.LIB -+ SELCHILD;"
	cd $(SELECT_DIR) && $(LIB) "SERVICES.LIB -+ SERVICES;"
	cd $(SELECT_DIR) && $(LIB) "SERVICES.LIB -+ GET_HELP;"
	cd $(SELECT_DIR) && $(LIB) "SERVICES.LIB -+ SELSERV;"

