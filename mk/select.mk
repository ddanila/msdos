	cd $(SELECT_DIR) && $(CL) "-AS -Od -Zp -I. -c -FoGLOBAL.OBJ GLOBAL.C"

# ---------------------------------------------------------------------------
# SELECT.EXE link
# ---------------------------------------------------------------------------
SELECT_OBJS := \
    $(SELECT_DIR)/SELECT0.OBJ $(SELECT_DIR)/SELECT1.OBJ \
    $(SELECT_DIR)/SELECT2.OBJ $(SELECT_DIR)/SELECT2A.OBJ \
    $(SELECT_DIR)/SELECT3.OBJ $(SELECT_DIR)/SELECT4.OBJ \
    $(SELECT_DIR)/SELECT5.OBJ $(SELECT_DIR)/SELECT5A.OBJ \
    $(SELECT_DIR)/SELECT6.OBJ $(SELECT_DIR)/SELECT7.OBJ \
    $(SELECT_DIR)/SELECT8.OBJ $(SELECT_DIR)/SELECT9.OBJ \
    $(SELECT_DIR)/ROUTINE2.OBJ $(SELECT_DIR)/GEN_COMS.OBJ \
    $(SELECT_DIR)/ROUTINES.OBJ $(SELECT_DIR)/INTVEC.OBJ \
    $(SELECT_DIR)/CKDISP.OBJ $(SELECT_DIR)/SCN_PARM.OBJ \
    $(SELECT_DIR)/PRN_DEF.OBJ $(SELECT_DIR)/VAR.OBJ \
    $(SELECT_DIR)/CASERVIC.OBJ $(SELECT_DIR)/INPUT.OBJ \
    $(SELECT_DIR)/INITMEM.OBJ $(SELECT_DIR)/MPARSE.OBJ \
    $(SELECT_DIR)/MOD_COPY.OBJ $(SELECT_DIR)/S_DISPLY.OBJ \
    $(SELECT_DIR)/BRIDGE.OBJ $(SELECT_DIR)/ASM2C.OBJ \
    $(SELECT_DIR)/GET_STAT.OBJ $(SELECT_DIR)/GLOBAL.OBJ \
    $(SELECT_DIR)/INT13.OBJ $(SELECT_DIR)/BOOTREC.OBJ \
    $(SELECT_DIR)/SERVICES.LIB

$(SELECT_DIR)/SELECT.EXE: $(SELECT_OBJS)
	cd $(SELECT_DIR) && $(LINK) "/noe @SELECT.LNK"
	$(BIN)/fix-exepack $(SELECT_DIR)/SELECT.EXE

# ---------------------------------------------------------------------------
# SELECT.DAT  (SEL-PAN objects → link → exe2bin → compress)
# ---------------------------------------------------------------------------
$(SELECT_DIR)/PANEL.INF: $(SELECT_DIR)/USA.INF
	cp $(SELECT_DIR)/USA.INF $(SELECT_DIR)/PANEL.INF

$(SELECT_DIR)/PANELS.OBJ: $(SELECT_DIR)/PANELS.ASM $(SELECT_DIR)/PANEL.INF
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) -I." "PANELS.ASM,PANELS.OBJ;"

$(SELECT_DIR)/COLORS.OBJ: $(SELECT_DIR)/COLORS.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) -I." "COLORS.ASM,COLORS.OBJ;"

$(SELECT_DIR)/SCROLL.OBJ: $(SELECT_DIR)/SCROLL.ASM $(SELECT_DIR)/PANEL.INF
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) -I." "SCROLL.ASM,SCROLL.OBJ;"

$(SELECT_DIR)/SEL-PAN.OBJ: $(SELECT_DIR)/SEL-PAN.ASM
	cd $(SELECT_DIR) && $(MASM) "$(AFLAGS) $(SELECT_AINC)" "SEL-PAN.ASM,SEL-PAN.OBJ;"

$(SELECT_DIR)/SEL-PAN.EXE: \
    $(SELECT_DIR)/SEL-PAN.OBJ $(SELECT_DIR)/PANELS.OBJ \
    $(SELECT_DIR)/COLORS.OBJ $(SELECT_DIR)/SCROLL.OBJ
	cd $(SELECT_DIR) && $(LINK) "@SEL-PAN.LNK"

$(SELECT_DIR)/SEL-PAN.DAT: $(SELECT_DIR)/SEL-PAN.EXE
	cd $(SELECT_DIR) && $(EXE2BIN) "SEL-PAN.EXE SEL-PAN.DAT"

$(SELECT_DIR)/SELECT.DAT: $(SELECT_DIR)/SEL-PAN.DAT
	cd $(SELECT_DIR) && $(BIN)/dos-run $(TOOLS_DIR)/COMPRESS.COM
