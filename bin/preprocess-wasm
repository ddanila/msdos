#!/usr/bin/env python3
"""Preprocess ASM/INC files for WASM compatibility.

Renames STRUC.INC dot-macros (.IF/.ELSE/.ENDIF etc.) to $-prefixed names
to avoid clashes with WASM reserved words.  Also moves forward-declared
Class_X_MessageCount EQU lines to the top of CL* files.

Usage: preprocess-wasm <outdir> <source.ASM> [incdir ...]
"""
import os, re, sys, glob

# WASM doesn't support MASM RECORD instantiation syntax SF_BITS<align,,size,type>.
# Evaluate SF_BITS<...> at preprocessing time using the RECORD bit layout:
#   F_ALIGN:1, F_RES:1=0, F_SIZE:2, F_TYPE:4  (A0SSTTTT)
_SF_ALIGN = {'SF_LEFT': 0, 'SF_RIGHT': 1}
_SF_SIZE  = {'SF_CH': 0, 'SF_ASCIIZ': 1, 'SF_BYTE': 1, 'SF_WORD': 2, 'SF_DWORD': 3,
             'SF_MD': 1, 'SF_MDY2': 2, 'SF_MDY4': 3,
             'SF_HHMM': 0, 'SF_HHMMSS': 1, 'SF_HHMMSSHH': 2}
_SF_TYPE  = {'SF_CHAR': 0x00, 'SF_UN_BD': 0x01, 'SF_SIN_BD': 0x02,
             'SF_UN_BH': 0x03, 'SF_DATE': 0x04, 'SF_TIME_12': 0x05,
             'SF_TIME_24': 0x06}

def _eval_sfbits(m):
    """Replace SF_BITS<align,res,size,type> with a computed byte literal."""
    args = [a.strip() for a in m.group(1).split(',')]
    # args[0]=align, args[1]=res(ignored), args[2]=size, args[3]=type
    align = _SF_ALIGN.get(args[0].upper(), 0) if len(args) > 0 and args[0] else 0
    size  = _SF_SIZE.get(args[2].upper(), 0)   if len(args) > 2 and args[2] else 0
    typ   = _SF_TYPE.get(args[3].upper(), 0)   if len(args) > 3 and args[3] else 0
    val   = (align << 7) | (size << 4) | typ
    return '0%02XH' % val

# Match SF_BITS<...> with optional space before <, up to 4 comma-separated args
SF_BITS_PAT = re.compile(
    r'SF_BITS\s*<([^>]*)>',
    re.IGNORECASE,
)

DOT_PAT = re.compile(
    r'(?:^|(?<=\s))\.'
    r'((?i:if|else|elseif|endif|then|while|endwhile|repeat|until'
    r'|loop|for|next|leave|select|when|otherwise|endselect))'
    r'(?=[^a-zA-Z0-9_]|$)',
    re.MULTILINE,
)
FWD_PAT = re.compile(
    r'^(Class_\w+_MessageCount\s+EQU\s+\d+)\s*$',
    re.MULTILINE | re.IGNORECASE,
)
# WASM doesn't support %out — silently prevents OBJ generation
PCTOUT_PAT = re.compile(
    r'^\s*%out\b.*$',
    re.MULTILINE | re.IGNORECASE,
)
# WASM doesn't support MASM listing control directives
LISTING_PAT = re.compile(
    r'^\s*\.(?:LALL|SALL|XALL|LFCOND|SFCOND|TFCOND|XCREF|CREF|LIST|XLIST)\b.*$',
    re.MULTILINE | re.IGNORECASE,
)
# WASM segfaults on SUBTTL with long string arguments when STRUC.INC macros
# are loaded.  SUBTTL is a listing-only directive — strip it.
SUBTTL_PAT = re.compile(
    r'^\s*SUBTTL\b.*$',
    re.MULTILINE | re.IGNORECASE,
)
# BREAK and HEADER are MASM listing-control macros.  Some files use them
# before they're defined; WASM rejects the undefined call.  They're purely
# cosmetic (listing subtitle) — strip invocations and definitions.
BREAK_PAT = re.compile(
    r'^\s*BREAK\b(?!\s+MACRO\b).*$',
    re.MULTILINE | re.IGNORECASE,
)
HEADER_PAT = re.compile(
    r'^\s*HEADER\b(?!\s+(?:MACRO|STRUC|ENDS|SEGMENT|LABEL|EQU|=|DB|DW|DD|DQ|DT|PROC)\b).*$',
    re.MULTILINE | re.IGNORECASE,
)
BREAK_MACRO_DEF_PAT = re.compile(
    r'^\s*BREAK\s+MACRO\b[^\n]*(?:\n[^\n]*)*?\n\s*ENDM\b[^\n]*',
    re.MULTILINE | re.IGNORECASE,
)
HEADER_MACRO_DEF_PAT = re.compile(
    r'^\s*HEADER\s+MACRO\b[^\n]*(?:\n[^\n]*)*?\n\s*ENDM\b[^\n]*',
    re.MULTILINE | re.IGNORECASE,
)
# WASM forbids EQU redefinition (MASM allows same-value redefine).
# Wrap common redefined symbols in IFNDEF guards.
EQU_REDEF_PAT = re.compile(
    r'^((?:FALSE|TRUE|IBMJAPAN|IBMJAPVER|IBMVER|MSVER'
    r'|CR|LF|STDIN|STDOUT|STDERR'
    r'|Left_Align|Right_Align'
    r'|Char_Field_Char|Char_Field_ASCIIZ'
    r'|Unsgn_Bin_Byte|Unsgn_Bin_Word|Unsgn_Bin_DWord'
    r'|Sgn_Bin_Byte|Sgn_Bin_Word|Sgn_Bin_DWord'
    r'|Bin_Hex_Byte|Bin_Hex_Word|Bin_Hex_DWord'
    r'|FILL_OFF|FILL_SEG|DOS_KEYB_INP|LINE_FEED'
    r'|No_Error|Len_FS_String_Buffer|FCB1|NULL'
    r'|awrite|aread|bogus|IBM'
    r'|TAB|Sublist_Length|NO_REPLACE|Reserved'
    r'|MSG_SER_CLASS|EXT_ERR_CLASS|PARSE_ERR_CLASS|UTILITY_MSG_CLASS'
    r'|ERR_NOT_ENOUGH_MEM|ERR_OPENING_FILE|ERR_READING_FILE|ERR_FINDING_VALUE'
    r'|ERR_LINE_TOO_LONG|ERR_FINDING_NAME|ERR_ACCESSING_FILE|ERR_TOO_MANY_DEFS'
    r'|ERR_NUMBER_MATCH|ERR_ALLOCATING_MEM|ERR_CDP_CPP|ERR_PRN_DEFN'
    r'|PRESENT_WITH_PART|PRESENT_WITHOUT_PART|NOT_PRESENT'
    r'|NO_EDOS_SPACE|FREE_EDOS_SPACE|NO_EDOS_BUT_SPACE'
    r'|M_DOS_EXISTS|M_EDOS_EXISTS|M_LOGICAL_EXISTS|M_EDOS_SPACE|M_FREE_SPACE'
    r'|MULT_ANSI|INSTALL_CHECK|IOCTL_2F'
    r'|STDPRN|STDAUX|NO_INPUT|memS|lock_all|BP_START|ICB_OUT|HLP_OVER'
    r'|\$M_NUM_CLS'
    r'|number_of_CON_keywords|number_of_com_keywords'
    r'|IBMCOPYRIGHT|BUFFERFLAG|INTERNAT|KANJI|KOREA|JAPAN'
    r'|AINT|HARDINT|ExitCtrlC|ExitFatal|ExitNo|ExitOK'
    r'|FIRST_PARM_CT|ZERO_PARM_CT|MOFFSET|VID_SIZE'
    r'|Parse_Error_Class|NUL'
    r'|ROMFormat|ROMRead|ROMStatus|ROMVerify|ROMWrite'
    r'|ROMFORMAT|ROMREAD|ROMSTATUS|ROMVERIFY|ROMWRITE'
    r')\s+(?:equ|=)\s+.+)$',
    re.MULTILINE | re.IGNORECASE,
)

# Extensions to preprocess in include directories
INC_EXTS = {
    '.inc', '.asm', '.ctl', '.equ',
    '.cl1', '.cl2', '.cl3', '.cl4', '.cl5', '.cl6', '.cl7', '.cl8', '.cl9',
    '.cla', '.clb', '.clc', '.cld', '.cle',
}

# MASM allows +BYTE, +WORD, -BYTE as operand size arithmetic:
# [SI]+BYTE means [SI+1], [SI]+WORD means [SI+2], LETTER_A-BYTE means LETTER_A-1.
# WASM doesn't support this.  Replace +BYTE→+1, +WORD→+2, -BYTE→-1.
# Negative lookahead prevents matching "BYTE PTR" or "WORD PTR".
SIZE_OVERRIDE_PAT = re.compile(
    r'([+\-])\s*(BYTE|WORD)\b(?!\s+PTR)',
    re.IGNORECASE,
)

def _size_override_repl(m):
    """Replace +BYTE/+WORD/-BYTE with +1/+2/-1."""
    op = m.group(1)
    kw = m.group(2).upper()
    val = '1' if kw == 'BYTE' else '2'
    return op + val

# MASM's TYPE operator returns the size of a structure; WASM uses SIZE instead.
# Match TYPE as an operand (after comma or whitespace, not after a dot).
# Use [^\S\n]+ (non-newline whitespace) after TYPE to avoid eating line breaks
# when "type" appears at end of a comment line followed by code on the next line.
TYPE_OP_PAT = re.compile(
    r'(?<=[\s,(])(?i:type)[^\S\n]+(?=\w)',
)

# For WASM, cBegin/cEnd take the proc name as first argument.
# Detect cProc and inject name into subsequent cBegin/cEnd.
CPROC_PAT = re.compile(
    r'^(\s*cProc\s+(\w+)\s*(?:,.*)?)\s*$',
    re.MULTILINE | re.IGNORECASE,
)
CBEGIN_PAT = re.compile(
    r'^(\s*)cBegin\b(.*)',
    re.IGNORECASE,
)
CEND_PAT = re.compile(
    r'^(\s*)cEnd\b(.*)',
    re.IGNORECASE,
)

def inject_proc_names(text):
    """For WASM: inject cProc's name as first arg of subsequent cBegin/cEnd calls.

    cProc name,<attrs> ... cBegin [nogen] ... cEnd [nogen]
    becomes:
    cProc name,<attrs> ... cBegin _name[,nogen] ... cEnd _name[,nogen]

    Assumes ?PLM=0 (C calling convention) so C name is _name.
    Does not transform if cBegin/cEnd already have a non-blank first arg.
    """
    lines = text.split('\n')
    current_proc = None
    result = []
    for line in lines:
        m = CPROC_PAT.match(line)
        if m:
            current_proc = '_' + m.group(2)
            result.append(line)
            continue
        if current_proc:
            mb = CBEGIN_PAT.match(line)
            if mb:
                indent = mb.group(1)
                rest = mb.group(2).strip()
                # Only inject if rest is empty or starts with nogen
                if not rest or rest.lower().startswith('nogen'):
                    sep = ',' if rest else ''
                    result.append(f'{indent}cBegin {current_proc}{sep}{rest}')
                else:
                    result.append(line)
                continue
            me = CEND_PAT.match(line)
            if me:
                indent = me.group(1)
                rest = me.group(2).strip()
                if not rest or rest.lower().startswith('nogen'):
                    sep = ',' if rest else ''
                    result.append(f'{indent}cEnd {current_proc}{sep}{rest}')
                else:
                    result.append(line)
                # After cEnd, clear current proc
                current_proc = None
                continue
        result.append(line)
    return '\n'.join(result)

def resolve_wasm_conditionals(text):
    """Evaluate ifdef/ifndef __WASM__ blocks at preprocessing time.

    Since we are always preprocessing for WASM (__WASM__ is always defined),
    we can statically evaluate:
      - ifdef __WASM__ ... [else ...] endif  → keep the TRUE branch, drop the else
      - ifndef __WASM__ ... [else ...] endif → keep the ELSE branch (if any), drop the TRUE

    This prevents WASM from seeing &macro/&endm in skipped branches, which
    causes WASM's scanner to malfunction on subsequent conditional blocks.

    Only handles top-level (unnested) ifdef/ifndef __WASM__ blocks.
    Inner ifdef/ifndef blocks (non-__WASM__) are passed through unchanged.

    Correctly handles macro bodies: if/endif inside macro...endm are not
    counted as conditional nesting at the outer level.
    """
    # Patterns for the directives we care about (case-insensitive)
    IFDEF_WASM  = re.compile(r'^\s*ifdef\s+__WASM__\s*(?:;.*)?$', re.IGNORECASE)
    IFNDEF_WASM = re.compile(r'^\s*ifndef\s+__WASM__\s*(?:;.*)?$', re.IGNORECASE)
    # Generic ifdef/ifndef/if/ife/else/endif for nesting tracking.
    # Covers: if, ife, ifnb, ifidn, ifdif, ifb, ifdef, ifndef (and 2-char variants)
    COND_OPEN   = re.compile(r'^\s*(?:if(?:e|nb|idn|dif|b|def|ndef)?)\b', re.IGNORECASE)
    ELSE_PAT    = re.compile(r'^\s*else\b', re.IGNORECASE)
    ENDIF_PAT   = re.compile(r'^\s*endif\b', re.IGNORECASE)
    # Blocks that start an endm-terminated body (macros, loops)
    # These suspend conditional tracking until the matching endm.
    # Matches: "name macro", "irp x,<...>", "rept N", "for x,<...>"
    # Negative lookbehind excludes comment lines (starting with ;)
    ENDM_OPEN = re.compile(
        r'^(?!\s*;)\s*(?:\S+\s+macro\b|irp\b|rept\b|for\b)',
        re.IGNORECASE,
    )
    ENDM_CLOSE = re.compile(r'^\s*endm\b', re.IGNORECASE)

    def collect_block(lines, start):
        """Collect lines from start until we see else/endif at depth 0.
        Returns (true_lines, else_lines, end_idx) where end_idx points past endif.
        Correctly ignores if/endif INSIDE macro/irp/rept bodies.
        """
        i = start
        cond_depth = 0   # conditional nesting (only counted outside endm-blocks)
        endm_depth = 0   # macro/irp/rept nesting depth
        true_lines = []
        else_lines = None
        in_else = False

        def append(l):
            (else_lines if in_else else true_lines).append(l)

        while i < len(lines):
            l = lines[i]
            if endm_depth > 0:
                # Inside a macro/irp/rept body — don't count conditionals
                if ENDM_OPEN.match(l):
                    endm_depth += 1
                elif ENDM_CLOSE.match(l):
                    endm_depth -= 1
                append(l)
            else:
                # Outside any macro body
                if ENDM_OPEN.match(l):
                    endm_depth += 1
                    append(l)
                elif COND_OPEN.match(l):
                    cond_depth += 1
                    append(l)
                elif ENDIF_PAT.match(l) and cond_depth == 0:
                    # End of the outer ifdef/ifndef __WASM__ block
                    return true_lines, else_lines, i + 1
                elif ENDIF_PAT.match(l):
                    cond_depth -= 1
                    append(l)
                elif ELSE_PAT.match(l) and cond_depth == 0 and not in_else:
                    # Switch from true branch to else branch
                    in_else = True
                    else_lines = []
                else:
                    append(l)
            i += 1

        # Unterminated block (shouldn't happen in valid ASM)
        return true_lines, else_lines, i

    lines = text.split('\n')
    result = []
    i = 0
    endm_depth = 0  # track macro/irp/rept nesting in main loop
    while i < len(lines):
        line = lines[i]
        # Track macro nesting so we don't evaluate ifdef/ifndef __WASM__
        # inside macro bodies (they must be evaluated at expansion time).
        if ENDM_OPEN.match(line):
            endm_depth += 1
        elif ENDM_CLOSE.match(line) and endm_depth > 0:
            endm_depth -= 1
        if endm_depth == 0 and IFDEF_WASM.match(line):
            # Keep the TRUE branch, skip the ELSE branch
            true_lines, else_lines, end_idx = collect_block(lines, i + 1)
            inner = resolve_wasm_conditionals('\n'.join(true_lines))
            result.append(inner)
            i = end_idx
        elif endm_depth == 0 and IFNDEF_WASM.match(line):
            # Skip the TRUE branch, keep the ELSE branch
            true_lines, else_lines, end_idx = collect_block(lines, i + 1)
            if else_lines is not None:
                inner = resolve_wasm_conditionals('\n'.join(else_lines))
                result.append(inner)
            i = end_idx
        else:
            result.append(line)
            i += 1
    return '\n'.join(result)


# WASM forbids STRUC redefinition (MASM allows same-value redefine).
# Wrap STRUC..ENDS blocks in IFNDEF guards to prevent E046.
STRUC_DEF_PAT = re.compile(
    r'^(\w+)\s+STRUC\b',
    re.MULTILINE | re.IGNORECASE,
)
STRUC_ENDS_PAT = re.compile(
    r'^(\w+)\s+ENDS\b',
    re.MULTILINE | re.IGNORECASE,
)

def wrap_struc_ifndef(text):
    """Wrap STRUC..ENDS definitions in IFNDEF guards."""
    lines = text.split('\n')
    result = []
    in_struc = None  # name of current struct, or None
    struc_start_idx = None
    for i, line in enumerate(lines):
        if in_struc is None:
            m = STRUC_DEF_PAT.match(line)
            if m:
                name = m.group(1)
                # Don't guard segment definitions (NAME ENDS for segments)
                # Only guard actual STRUC definitions
                result.append(f'IFNDEF {name}')
                result.append(line)
                in_struc = name
                continue
        else:
            m = STRUC_ENDS_PAT.match(line)
            if m and m.group(1).lower() == in_struc.lower():
                result.append(line)
                result.append('ENDIF')
                in_struc = None
                continue
        result.append(line)
    return '\n'.join(result)

WASM_COND_PAT = re.compile(r'^\s*(?:ifdef|ifndef)\s+__WASM__', re.IGNORECASE | re.MULTILINE)

def needs_transform(text):
    """Quick check if text contains any patterns needing transformation."""
    return (DOT_PAT.search(text) is not None
            or STRUC_MACRO_PAT.search(text) is not None
            or FWD_PAT.search(text) is not None
            or PCTOUT_PAT.search(text) is not None
            or LISTING_PAT.search(text) is not None
            or EQU_REDEF_PAT.search(text) is not None
            or STRUC_DEF_PAT.search(text) is not None
            or SF_BITS_PAT.search(text) is not None
            or CPROC_PAT.search(text) is not None
            or WASM_COND_PAT.search(text) is not None
            or SUBTTL_PAT.search(text) is not None
            or BREAK_PAT.search(text) is not None
            or HEADER_PAT.search(text) is not None
            or BREAK_MACRO_DEF_PAT.search(text) is not None
            or HEADER_MACRO_DEF_PAT.search(text) is not None
            or OPTION_MACRO_PAT.search(text) is not None
            or SIZE_OVERRIDE_PAT.search(text) is not None
            or TYPE_OP_PAT.search(text) is not None
            or INVOKE_PAT.search(text) is not None
            or ENTER_MACRO_PAT.search(text) is not None
            or MEXIT_MACRO_PAT.search(text) is not None
            or STR_STRUC_PAT.search(text) is not None
            or STR_SIZE_PAT.search(text) is not None
            or NOT_MEM_OPERAND_PAT.search(text) is not None
            or ADDR_FIELD_DEF_PAT.search(text) is not None
            or ADDR_MEMBER_ACCESS_PAT.search(text) is not None
)

def _wrap_equ_ifndef(m):
    """Wrap an EQU definition in IFNDEF guard."""
    line = m.group(1)
    sym = line.split()[0]
    return f'IFNDEF {sym}\n{line}\nENDIF'

def _comma_sep_struc_args(m):
    """Convert space-separated STRUC.INC macro args to comma-separated for WASM.

    MASM splits macro arguments on both commas AND spaces.
    WASM only splits on commas.  STRUC.INC macros like $IF/$WHILE/$WHEN
    rely on space-separation, e.g. `.IF <ax EQ 0> near AND`.
    """
    keyword = m.group(1)  # IF, WHILE, etc.
    rest = m.group(2)     # everything after the keyword
    comment_start = rest.find(';')
    if comment_start >= 0:
        args_part = rest[:comment_start]
        comment = rest[comment_start:]
    else:
        args_part = rest
        comment = ''

    # Convert spaces inside angle brackets to commas: <X OP Y> → <X,OP,Y>
    # Only at depth 1 (outermost brackets); nested <<WORD PTR X> NE 0> keeps
    # inner spaces intact since they are assembly operands, not macro args.
    def fix_angles(s):
        result = []
        depth = 0
        prev_was_space = False
        for ch in s:
            if ch == '<':
                depth += 1
                result.append(ch)
                prev_was_space = False
            elif ch == '>':
                depth -= 1
                result.append(ch)
                prev_was_space = False
            elif ch == ' ' and depth == 1:
                if not prev_was_space:
                    result.append(',')
                prev_was_space = True
            else:
                result.append(ch)
                prev_was_space = False
        return ''.join(result)

    args_part = fix_angles(args_part)

    # Convert remaining spaces between top-level args to commas
    # e.g. "$IF NZ OR" → "$IF NZ,OR"
    # e.g. "$IF <ax,EQ,0> near AND" → "$IF <ax,EQ,0>,near,AND"
    tokens = []
    current = ''
    depth = 0
    for ch in args_part:
        if ch == '<':
            depth += 1
            current += ch
        elif ch == '>':
            depth -= 1
            current += ch
        elif (ch == ' ' or ch == '\t') and depth == 0:
            if current.strip():
                tokens.append(current.strip())
                current = ''
            # skip whitespace
        else:
            current += ch
    if current.strip():
        tokens.append(current.strip())

    if tokens:
        args_str = ','.join(tokens)
    else:
        args_str = ''

    return f'${keyword}\t{args_str}{comment}'

# WASM splits macro args on commas only; MASM also splits on spaces.
# Convert space-separated args in STRUC.INC macro invocations.
# Exclude macro DEFINITIONS (`.if macro t,p2,p3`) by negative lookahead.
STRUC_MACRO_PAT = re.compile(
    r'^\s*\.'
    r'((?:IF|ELSEIF|WHILE|UNTIL|WHEN|LEAVE)\b)'
    r'(?!\s+macro\b)'
    r'(.*?)$',
    re.MULTILINE | re.IGNORECASE,
)

# WASM reserves OPTION as a directive.  Rename the KEYBMAC.INC OPTION macro
# and all its call sites to KB_OPTION.  Only match OPTION at statement position
# (start of line or after whitespace), not inside OPTION_COMMAND or comments.
OPTION_MACRO_PAT = re.compile(
    r'^(\s*)OPTION(\s+(?:MACRO|EXIT_IF_FOUND)\b)',
    re.MULTILINE | re.IGNORECASE,
)

# WASM reserves INVOKE as a directive (call with type checking).  The DOSMAC.INC
# `invoke` macro and all its call sites must be renamed.  Match `invoke` as a
# whole word — also catches `.xcref invoke` and comment occurrences (harmless).
INVOKE_PAT = re.compile(
    r'\binvoke\b',
    re.IGNORECASE,
)

# WASM treats ENTER as the x86 ENTER instruction, blocking MAPPER's MACROS.INC
# `Enter` macro (which saves registers/sets up frame).  Rename the macro
# definition and all call sites.  Match Enter at statement position followed by
# a word (the routine name argument) or "macro" (the definition).
ENTER_MACRO_PAT = re.compile(
    r'^(\s*)Enter(\s+(?:macro|[A-Za-z_]\w*))',
    re.MULTILINE | re.IGNORECASE,
)

# WASM reserves MEXIT as a directive (exit macro expansion).  MAPPER's
# MACROS.INC defines a `Mexit` macro (restores registers/frame).  Only rename
# at statement position OUTSIDE macro/irp/rept bodies (inside those bodies,
# mexit is the real WASM directive).
MEXIT_MACRO_PAT = re.compile(
    r'^(\s*)mexit\b',
    re.MULTILINE | re.IGNORECASE,
)

# MAPPER files name their stack-frame structure `str`, which may conflict with
# WASM internals.  Rename to `stkfrm` in structure definitions, ends, and
# SIZE references.
STR_STRUC_PAT = re.compile(
    r'\bstr\b(?=\s+(?:struc|ends)\b)',
    re.IGNORECASE,
)
# Use capturing group (not lookbehind) to handle variable whitespace between
# SIZE and str.
STR_SIZE_PAT = re.compile(
    r'\b(size\s+)str\b',
    re.IGNORECASE,
)

# WASM reserves ADDR as an operator.  Rename `addr` when used as a struct
# member name: field definitions and [reg].addr member accesses.
# Restricted to struct context to avoid false positives.
# WASM `not` on a 16-bit EQU value produces a 32-bit result, causing E102
# (386 operand size) when used with unsized memory operands (e.g., ds:[si]).
# Add explicit WORD PTR and mask to 16 bits.  Only match memory operands
# of the form seg:[reg] or [reg] (no explicit PTR override) with `not`.
NOT_MEM_OPERAND_PAT = re.compile(
    r'^(\s*(?:and|or|test|xor)\s+)'
    r'((?:(?:ds|es|cs|ss):)?\[[^\]]+\])'
    r'(\s*,\s*)'
    r'not\s+(\w+)',
    re.MULTILINE | re.IGNORECASE,
)

ADDR_FIELD_DEF_PAT = re.compile(
    r'^(addr)(\s+d[bdwqt]\s)',
    re.MULTILINE | re.IGNORECASE,
)
ADDR_MEMBER_ACCESS_PAT = re.compile(
    r'(\.)(addr)\b',
    re.IGNORECASE,
)


_MEXIT_ENDM_OPEN = re.compile(
    r'^(?!\s*;)\s*(?:\S+\s+macro\b|irp\b|rept\b|for\b)',
    re.IGNORECASE,
)
_MEXIT_ENDM_CLOSE = re.compile(r'^\s*endm\b', re.IGNORECASE)

_MEXIT_DEF_PAT = re.compile(
    r'^(\s*)(mexit)(\s+macro\b)',
    re.IGNORECASE,
)

def rename_mexit_outside_macros(text):
    """Rename `mexit` to `do_mexit` only outside macro/irp/rept bodies.

    Inside macro bodies, mexit is the real WASM directive (exit macro
    expansion) and must NOT be renamed.  Outside, it's MAPPER's MACROS.INC
    `Mexit` macro (restores registers/frame) and must be renamed.
    Also renames the macro definition itself (`Mexit macro` → `do_mexit macro`).
    """
    lines = text.split('\n')
    endm_depth = 0
    result = []
    for line in lines:
        # Rename the macro definition line before tracking depth
        m = _MEXIT_DEF_PAT.match(line)
        if m:
            line = m.group(1) + 'do_mexit' + m.group(3)
            endm_depth += 1
        elif _MEXIT_ENDM_OPEN.match(line):
            endm_depth += 1
        elif _MEXIT_ENDM_CLOSE.match(line) and endm_depth > 0:
            endm_depth -= 1
        if endm_depth == 0:
            line = MEXIT_MACRO_PAT.sub(r'\1do_mexit', line)
        result.append(line)
    return '\n'.join(result)

# STRUC.INC's $BuildJump macro defines jump aliases via nested macro-inside-macro.
# WASM can't handle this (E235 "Procedure must have a name").  Pre-expand all
# jump aliases at preprocessing time since the irp arguments are static.
_BUILDJUMP_BLOCK_PAT = re.compile(
    r'^\$BuildJump\s+macro\s+j1\s*,\s*j2\b.*?^purge\s+\$BuildJump\b[^\n]*',
    re.MULTILINE | re.DOTALL | re.IGNORECASE,
)

# All jump aliases produced by the three irp loops in STRUC.INC:
_JUMP_ALIASES = [
    # irp 1: pairs
    ('jeq', 'je'), ('jlt', 'jl'), ('jgt', 'jg'), ('jneq', 'jne'),
    ('jnlt', 'jnl'), ('jngt', 'jng'), ('jnpe', 'jpo'), ('jnpo', 'jpe'),
    # irp 2: zero/nonzero/bit-test aliases
    ('jzero', 'jz'), ('jnzero', 'jnz'), ('jnonzero', 'jnz'),
    ('jnnonzero', 'jz'), ('jand', 'jnz'), ('jnand', 'jz'), ('jnnand', 'jnz'),
    # irp 3: jnn&x → j&x for each suffix
    ('jnna', 'ja'), ('jnnae', 'jae'), ('jnnb', 'jb'), ('jnnbe', 'jbe'),
    ('jnnc', 'jc'), ('jnne', 'je'), ('jnng', 'jg'), ('jnnge', 'jge'),
    ('jnnl', 'jl'), ('jnnle', 'jle'), ('jnno', 'jo'), ('jnnp', 'jp'),
    ('jnns', 'js'), ('jnnz', 'jz'), ('jnncxz', 'jcxz'),
]

def _expand_buildjump(m):
    """Replace $BuildJump block with pre-expanded jump alias macros."""
    lines = ['; WASM: $BuildJump pre-expanded by preprocessor']
    for alias, target in _JUMP_ALIASES:
        lines.append(f'{alias}\tmacro\tt')
        lines.append(f'\t\t\t\t\t{target} t')
        lines.append('endm')
    # jncxz is defined separately in the original — keep it as-is since
    # it's a standalone macro, not nested.  It's right before `purge` in
    # the matched block, so we need to re-emit it.
    lines.append('jncxz\tmacro\tt')
    lines.append('\tif\t$Dist eq $NearToShort')
    lines.append('\t\t\t\t\tjcxz $+5')
    lines.append('\t\t\t\t\tjmp t')
    lines.append('\telse')
    lines.append('\t\t\t\t\tjcxz $+4')
    lines.append('\t\t\t\t\tjmp short t')
    lines.append('\tendif')
    lines.append('endm')
    return '\n'.join(lines)

def transform(text):
    """Apply dot-macro rename, CL forward-ref fix, %out removal, EQU guards, SF_BITS expansion,
    and cProc/cBegin/cEnd name injection for WASM."""
    # Pre-expand $BuildJump nested macros before any other transforms
    text = _BUILDJUMP_BLOCK_PAT.sub(_expand_buildjump, text)
    # Evaluate ifdef/ifndef __WASM__ blocks first to eliminate MASM-only branches
    # (prevents WASM scanner bug with &macro/&endm in skipped branches)
    text = resolve_wasm_conditionals(text)
    # Expand SF_BITS<...> RECORD instantiations before other transforms
    text = SF_BITS_PAT.sub(_eval_sfbits, text)
    # Must comma-separate STRUC.INC macro args BEFORE renaming . to $
    text = STRUC_MACRO_PAT.sub(_comma_sep_struc_args, text)
    text = DOT_PAT.sub(lambda m: '$' + m.group(1), text)
    text = PCTOUT_PAT.sub(r'; (removed for WASM)', text)
    text = LISTING_PAT.sub(r'; (listing directive removed for WASM)', text)
    text = SUBTTL_PAT.sub(r'; (SUBTTL removed for WASM)', text)
    text = BREAK_MACRO_DEF_PAT.sub(r'; (BREAK MACRO definition removed for WASM)', text)
    text = HEADER_MACRO_DEF_PAT.sub(r'; (HEADER MACRO definition removed for WASM)', text)
    text = BREAK_PAT.sub(r'; (BREAK removed for WASM)', text)
    text = HEADER_PAT.sub(r'; (HEADER removed for WASM)', text)
    text = OPTION_MACRO_PAT.sub(r'\1KB_OPTION\2', text)
    text = INVOKE_PAT.sub('do_invoke', text)
    text = ENTER_MACRO_PAT.sub(r'\1do_enter\2', text)
    text = rename_mexit_outside_macros(text)
    text = STR_STRUC_PAT.sub('stkfrm', text)
    text = STR_SIZE_PAT.sub(r'\1stkfrm', text)
    text = NOT_MEM_OPERAND_PAT.sub(r'\1WORD PTR \2\3((not \4) and 0FFFFh)', text)
    text = ADDR_FIELD_DEF_PAT.sub(r'saddr\2', text)
    text = ADDR_MEMBER_ACCESS_PAT.sub(r'\1saddr', text)
    text = EQU_REDEF_PAT.sub(_wrap_equ_ifndef, text)
    text = wrap_struc_ifndef(text)  # disabled — causes regressions
    fwd_lines = FWD_PAT.findall(text)
    if fwd_lines:
        text = '\n'.join(fwd_lines) + '\n' + FWD_PAT.sub(r'; (moved to top) \1', text)
    # Replace MASM operand size overrides: +BYTE→+1, +WORD→+2, -BYTE→-1
    text = SIZE_OVERRIDE_PAT.sub(_size_override_repl, text)
    # Replace MASM TYPE operator with WASM SIZE equivalent
    text = TYPE_OP_PAT.sub('SIZE ', text)
    # Inject proc names into cBegin/cEnd for WASM compatibility
    text = inject_proc_names(text)
    return text

# WASM treats EXTRN xxx:ABS as WORD-sized, causing E050 when compared with
# BYTE operands.  Collect PUBLIC EQU definitions from the source directory
# and replace EXTRN xxx:ABS with local EQU definitions.
EXTRN_ABS_PAT = re.compile(
    r'^\s*EXTRN\s+(\w+)\s*:\s*ABS\b',
    re.MULTILINE | re.IGNORECASE,
)
# Match "name EQU value" where name is PUBLIC'd
EQU_DEF_PAT = re.compile(
    r'^\s*(\w+)\s+(?:EQU|=)\s+(.+?)(?:\s*;.*)?$',
    re.MULTILINE | re.IGNORECASE,
)
PUBLIC_PAT = re.compile(
    r'^\s*PUBLIC\s+(.*)',
    re.MULTILINE | re.IGNORECASE,
)

_abs_equ_map = {}  # populated by main() before processing

def _collect_abs_equs(srcdir):
    """Scan source directory for PUBLIC EQU definitions to resolve EXTRN:ABS."""
    equs = {}   # name (lower) → value string
    publics = set()
    for entry in os.listdir(srcdir):
        ext = os.path.splitext(entry)[1].lower()
        if ext not in INC_EXTS:
            continue
        try:
            with open(os.path.join(srcdir, entry), 'rb') as f:
                text = f.read().decode('latin-1')
        except (IOError, UnicodeDecodeError):
            continue
        for m in PUBLIC_PAT.finditer(text):
            for name in m.group(1).split(','):
                name = name.strip().split()[0] if name.strip() else ''
                if name:
                    publics.add(name.lower())
        for m in EQU_DEF_PAT.finditer(text):
            name = m.group(1)
            val = m.group(2).strip()
            equs[name.lower()] = (name, val)
    # Only keep EQUs that are PUBLIC and have simple constant values
    # (reject values containing $, labels, register names, or expressions)
    simple_val = re.compile(r'^[0-9][0-9A-Fa-f]*[Hh]?$|^0[Xx][0-9A-Fa-f]+$|^[0-9]+$|^-?[0-9]+$')
    return {k: v for k, v in equs.items()
            if k in publics and simple_val.match(v[1])}

def _replace_extrn_abs(m):
    """Replace EXTRN name:ABS with local EQU if value is known."""
    name = m.group(1)
    key = name.lower()
    if key in _abs_equ_map:
        orig_name, val = _abs_equ_map[key]
        return f'{name}\tEQU\t{val}\t; WASM: was EXTRN {name}:ABS'
    return m.group(0)  # keep original if value unknown

def process_file(src, dst):
    """Read src, transform if needed, write to dst."""
    with open(src, 'rb') as f:
        raw = f.read()
    text = raw.decode('latin-1')
    # Replace EXTRN:ABS with local EQU before other transforms
    if EXTRN_ABS_PAT.search(text):
        text = EXTRN_ABS_PAT.sub(_replace_extrn_abs, text)
        raw = text.encode('latin-1')
    if needs_transform(text):
        text = transform(text)
        raw = text.encode('latin-1')
    with open(dst, 'wb') as f:
        f.write(raw)

def main():
    global _abs_equ_map
    outdir = sys.argv[1]
    source = sys.argv[2]
    incdirs = sys.argv[3:]

    # Collect PUBLIC EQU definitions to resolve EXTRN:ABS
    srcdir = os.path.dirname(source) or '.'
    _abs_equ_map = _collect_abs_equs(srcdir)

    # Preprocess source file and all include-able files in source directory
    process_file(source, os.path.join(outdir, os.path.basename(source)))
    srcdir = os.path.dirname(source) or '.'
    for entry in os.listdir(srcdir):
        ext = os.path.splitext(entry)[1].lower()
        if ext in INC_EXTS and entry != os.path.basename(source):
            process_file(os.path.join(srcdir, entry), os.path.join(outdir, entry))

    # Preprocess include directories
    srcdir_real = os.path.realpath(srcdir)
    for incdir in incdirs:
        if not os.path.isdir(incdir):
            continue
        # Skip if incdir is the same as srcdir — those files are already at outdir root
        if os.path.realpath(incdir) == srcdir_real:
            continue
        ppinc = os.path.join(outdir, 'inc_' + incdir.replace('/', '_').replace('.', '_').replace('=', '_'))
        os.makedirs(ppinc, exist_ok=True)
        for entry in os.listdir(incdir):
            ext = os.path.splitext(entry)[1].lower()
            if ext in INC_EXTS:
                process_file(os.path.join(incdir, entry), os.path.join(ppinc, entry))

if __name__ == '__main__':
    main()
