#!/bin/bash
# Generic kvikdos runner.
# Usage: dos-run <DOS-tool-path> [args...]
#
# Mounts:
#   C: -> MS-DOS 4.0 source root (uppercase mode)
#   --cwd sets initial DOS current directory to the current Linux subdir
#
# This allows DOS relative paths like ..\INC to work correctly from
# any subdirectory of the source tree.

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
KVIKDOS="$SCRIPT_DIR/../kvikdos/kvikdos"
SRC_ROOT="$(cd "$SCRIPT_DIR/../MS-DOS/v4.0/src" && pwd)"

TOOL="$1"
shift

# Compute the DOS current directory (subdir relative to source root)
CWD="$(pwd)"
if [[ "$CWD" == "$SRC_ROOT"* ]]; then
    DOSREL="${CWD#$SRC_ROOT}"
    DOSREL="${DOSREL#/}"   # strip leading /
    DOSREL="${DOSREL//\//\\}" # convert / to backslash
    if [ -n "$DOSREL" ]; then
        CWD_ARG="--cwd=C:\\${DOSREL}\\"
    else
        CWD_ARG=""
    fi
else
    CWD_ARG=""
fi

exec "$KVIKDOS" \
    --mount=c:"$SRC_ROOT"/ \
    --drive=c \
    $CWD_ARG \
    --env="PATH=c:\\TOOLS" \
    --env="INCLUDE=c:\\TOOLS\\BLD\\INC" \
    --env="LIB=c:\\TOOLS\\BLD\\LIB" \
    --env="INIT=c:\\TOOLS" \
    --env="COUNTRY=usa-ms" \
    "$TOOL" \
    "$@"
