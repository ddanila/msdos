#!/bin/bash
# wasm-masm — wrapper that translates MASM-style invocation to Open Watcom WASM
#
# MASM invocation:  masm "flags" "source.ASM,output.OBJ;"
# WASM equivalent:  wasm -zcm=masm [translated flags] source.ASM -fo=output.OBJ
#
# Translation:
#   -Mx (preserve case externals) → WASM default (case-sensitive), dropped
#   -t  (terse output)            → no WASM equivalent, dropped
#   -ID:\TOOLS\INC                → dropped (redundant with relative -I paths)
#   -I<path> with backslashes     → converted to forward slashes
#   -D<name>=<val>                → passed through as-is

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Platform-detect WASM binary
case "$(uname -s)-$(uname -m)" in
    Linux-x86_64)  WASM="$SCRIPT_DIR/../watcom/bin/linux-x64/wasm" ;;
    Darwin-arm64)  WASM="$SCRIPT_DIR/../watcom/bin/macos-arm64/wasm" ;;
    *) echo "Unsupported platform: $(uname -s)-$(uname -m)" >&2; exit 1 ;;
esac

# Parse arguments: "$1" = flags, "$2" = "source,output;"
FLAGS="$1"
FILESPEC="$2"

# Strip trailing semicolon and split on comma
FILESPEC="${FILESPEC%;}"
SOURCE="${FILESPEC%%,*}"
OUTPUT="${FILESPEC#*,}"

# Translate MASM flags to WASM flags
WASM_FLAGS=()
INC_DIRS=()
for flag in $FLAGS; do
    case "$flag" in
        -Mx|-t)           ;; # MASM-specific, not needed
        -I[A-Z]:\\*)       ;; # DOS absolute path (e.g., -ID:\TOOLS\INC), skip
        -I*)
            # Convert backslashes to forward slashes
            flag="${flag//\\//}"
            WASM_FLAGS+=("$flag")
            INC_DIRS+=("${flag#-I}")
            ;;
        *)
            WASM_FLAGS+=("$flag")
            ;;
    esac
done

# Preprocess: rename STRUC.INC dot-macros that clash with WASM reserved words.
# .IF/.ELSE/.ENDIF → $IF/$ELSE/$ENDIF etc.  Also fix CL file forward references.
# Single Python invocation processes source + all include dirs.
PPDIR=$(mktemp -d)
trap 'rm -rf "$PPDIR"' EXIT

python3 "$SCRIPT_DIR/preprocess-wasm" "$PPDIR" "$SOURCE" "${INC_DIRS[@]}"

PP_SOURCE="$PPDIR/$(basename "$SOURCE")"

# Build new -I flags: shadow dirs first, then originals as fallback.
# Convert relative -I paths to absolute since we'll cd to PPDIR.
ORIG_DIR="$(pwd)"
PP_WASM_FLAGS=()
for flag in "${WASM_FLAGS[@]}"; do
    case "$flag" in
        -I*)
            incdir="${flag#-I}"
            # Make relative paths absolute (we'll cd to PPDIR later)
            case "$incdir" in
                /*) abs_incdir="$incdir" ;;
                *)  abs_incdir="$ORIG_DIR/$incdir" ;;
            esac
            ppinc="$PPDIR/inc_$(echo "$incdir" | tr '/.=' '___')"
            if [ -d "$ppinc" ]; then
                PP_WASM_FLAGS+=("-I$ppinc" "-I$abs_incdir")
            else
                PP_WASM_FLAGS+=("-I$abs_incdir")
            fi
            ;;
        *)
            PP_WASM_FLAGS+=("$flag")
            ;;
    esac
done

# Run WASM from the preprocessed directory so CWD-relative includes find
# preprocessed CL files instead of originals.
PP_SOURCE_BASE="$(basename "$PP_SOURCE")"
# Convert OUTPUT to absolute path
case "$OUTPUT" in
    /*) ABS_OUTPUT="$OUTPUT" ;;
    *)  ABS_OUTPUT="$ORIG_DIR/$OUTPUT" ;;
esac
cd "$PPDIR"
"$WASM" -zcm=masm "${PP_WASM_FLAGS[@]}" "$PP_SOURCE_BASE" -fo="$ABS_OUTPUT" || { rc=$?; cd "$ORIG_DIR"; exit $rc; }
cd "$ORIG_DIR"

# Strip WASM auto-generated _TEXT/_DATA segments: their CODE/DATA class causes
# MS LINK to place CODE before START in DOSGROUP, breaking OFFSET DOSGROUP:INITBLOCK.
python3 "$SCRIPT_DIR/strip-wasm-segs" "$OUTPUT"
